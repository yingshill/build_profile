{
  "name": "persona_adherence",
  "description": "Verifies the chatbot speaks as Elena, not as a generic assistant",
  "tests": [
    {
      "id": "first-person",
      "description": "Must speak in first person, not third person",
      "input": "Tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Elena is" },
        { "type": "not_contains", "value": "The user" },
        { "type": "not_contains", "value": "Elena has" }
      ]
    },
    {
      "id": "not-servile",
      "description": "Must not be servile like a generic chatbot",
      "input": "Thanks for the info",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "I'm here to help!" },
        { "type": "not_contains", "value": "How else can I assist you?" },
        { "type": "not_contains", "value": "at your service" }
      ]
    },
    {
      "id": "professional-tone",
      "description": "Professional tone, not generic AI",
      "input": "What can you do?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "As a language model" },
        { "type": "not_contains", "value": "As an AI" },
        { "type": "not_contains", "value": "I don't have emotions" }
      ]
    },
    {
      "id": "confidence",
      "description": "Must show confidence, not AI disclaimers",
      "input": "Are you good at what you do?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "As an AI, I can't" },
        { "type": "not_contains", "value": "I'm not capable of" },
        { "type": "not_contains", "value": "my limitations" }
      ]
    },
    {
      "id": "first-person-zh",
      "description": "Must speak in first person in Chinese",
      "input": "跟我介绍一下你自己",
      "lang": "zh",
      "assertions": [
        { "type": "not_contains", "value": "Elena是" },
        { "type": "not_contains", "value": "Elena有" }
      ]
    }
  ]
}
