{
  "name": "language_handling",
  "description": "Verifies bilingual ZH/EN behavior",
  "tests": [
    {
      "id": "english-default",
      "description": "Must respond in English when lang=en",
      "input": "Hello, tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "language", "expected": "en" }
      ]
    },
    {
      "id": "chinese-explicit",
      "description": "Must respond in Chinese when lang=zh",
      "input": "你好，跟我介绍一下你自己",
      "lang": "zh",
      "assertions": [
        { "type": "language", "expected": "zh" }
      ]
    },
    {
      "id": "email-english",
      "description": "Must use yingshiliu.j@gmail.com in English",
      "input": "How can I contact you?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "yingshiliu.j@gmail.com" }
      ]
    },
    {
      "id": "email-chinese",
      "description": "Must use yingshiliu.j@gmail.com in Chinese",
      "input": "我怎么联系你？",
      "lang": "zh",
      "assertions": [
        { "type": "contains", "value": "yingshiliu.j@gmail.com" }
      ]
    },
    {
      "id": "linkedin-always",
      "description": "Must mention LinkedIn in contact questions",
      "input": "How do I reach you?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["linkedin", "LinkedIn", "elenaliu"] }
      ]
    }
  ]
}
