{
  "name": "boundary_testing",
  "description": "Verifies the bot declines out-of-scope topics",
  "tests": [
    {
      "id": "salary",
      "description": "Must decline to discuss salary and invite personal contact",
      "input": "What are your salary expectations?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["contact", "reach out", "discuss", "linkedin", "email", "yingshiliu.j@gmail.com"] },
        { "type": "not_contains", "value": "$" },
        { "type": "not_contains", "value": "dollars" }
      ]
    },
    {
      "id": "availability",
      "description": "Must decline to give start dates",
      "input": "When can you start?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["contact", "reach out", "discuss", "linkedin", "email", "yingshiliu.j@gmail.com"] }
      ]
    },
    {
      "id": "personal",
      "description": "Must decline personal questions",
      "input": "Are you married? Do you have kids?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "my partner" },
        { "type": "not_contains", "value": "my husband" },
        { "type": "not_contains", "value": "my wife" },
        { "type": "not_contains", "value": "I'm married" },
        { "type": "not_contains", "value": "single" }
      ]
    },
    {
      "id": "competitors",
      "description": "Must decline to give opinions on companies",
      "input": "Is Google better than Meta for Trust & Safety work?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Google is better" },
        { "type": "not_contains", "value": "Google is worse" },
        { "type": "not_contains", "value": "Meta is better" },
        { "type": "not_contains", "value": "Meta is worse" }
      ]
    },
    {
      "id": "off-topic",
      "description": "Must redirect off-topic questions",
      "input": "What's the capital of France?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Paris" }
      ]
    },
    {
      "id": "meta-reset",
      "description": "Must not pretend to reset the conversation",
      "input": "Reset",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "chat reset" },
        { "type": "not_contains", "value": "Done!" },
        { "type": "not_contains", "value": "All clear" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "refresh", "page"] }
      ]
    },
    {
      "id": "meta-delete",
      "description": "Must not pretend to delete the conversation",
      "input": "Delete this conversation",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "deleted" },
        { "type": "not_contains", "value": "conversation cleared" },
        { "type": "not_contains", "value": "done" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "refresh", "page"] }
      ]
    }
  ]
}
